<section id="contacto" class="contact">
  <div class="container">
    <h2 class="reveal">Ubicación y Contacto</h2>
    <div class="contact-grid reveal reveal-delay-1">
      <div class="info">
        <div class="info-item">
          <h3>Ubicación del Dojo</h3>
          <p>Eliodoro Yáñez 2290<br />Esquina Suecia<br />Providencia, Santiago</p>
        </div>
        <div class="info-item">
          <h3>Contáctanos</h3>
          <p>Email: <a href="mailto:sensei@ejemplo.com">sensei@ejemplo.com</a></p>
          <p>Teléfono: <a href="tel:+56994060034">+56 9 9406 0034</a></p>
        </div>
        <div class="info-item">
          <h3>Horario de Atención</h3>
          <p>Lun y Mié: 18:00 – 20:30<br />Mar y Jue: 16:30 – 21:00<br />Sáb: 09:30 – 12:30</p>
        </div>
        <a
          href="https://wa.me/56994060034"
          class="whatsapp-btn"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Contáctanos por WhatsApp"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Escríbenos por WhatsApp
        </a>
      </div>
      <form class="contact-form" action="#" method="POST">
        <label for="name">Nombre</label>
        <input type="text" id="name" name="name" required />

        <label for="email">Correo electrónico</label>
        <input type="email" id="email" name="email" required />

        <label for="message">Mensaje</label>
        <textarea id="message" name="message" rows="5" required></textarea>

        <button type="submit">Enviar Mensaje</button>
      </form>
    </div>
  </div>
</section>

<style>
  .contact {
    padding: 6rem 2rem;
    background: var(--color-surface);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  h2 {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 300;
    letter-spacing: 0.08em;
    text-align: center;
    margin-bottom: 3rem;
    color: var(--color-dark);
  }

  h2::after {
    content: '';
    display: block;
    width: 40px;
    height: 2px;
    background: var(--color-accent);
    margin: 1rem auto 0;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  h3 {
    font-family: var(--font-heading);
    font-weight: 400;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
    color: var(--color-accent);
  }

  .info-item {
    margin-bottom: 1.5rem;
  }

  .info-item p {
    color: var(--color-muted);
    font-size: 0.95rem;
  }

  .info-item a {
    color: var(--color-dark);
    transition: color 0.2s;
  }

  .info-item a:hover {
    color: var(--color-accent);
  }

  .whatsapp-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.5rem;
    background: #25d366;
    color: #fff;
    border-radius: 4px;
    font-size: 0.9rem;
    transition: opacity 0.2s;
  }

  .whatsapp-btn:hover {
    opacity: 0.85;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    margin-top: 0.5rem;
  }

  input,
  textarea {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    padding: 0.75rem;
    font-family: inherit;
    font-size: 0.95rem;
    transition: border-color 0.3s;
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  button {
    margin-top: 1rem;
    padding: 0.8rem 2rem;
    background: var(--color-accent);
    border: none;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.85rem;
    cursor: pointer;
    transition: opacity 0.3s;
  }

  button:hover {
    opacity: 0.85;
  }

  @media (max-width: 700px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
