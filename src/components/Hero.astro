---
---

<section class="hero">
  <div class="hero-text">
    <p class="subtitle hero-anim">El Arte de la Paz</p>
    <h1 class="hero-anim">Aikido</h1>
    <p class="tagline hero-anim">Armonía en movimiento.<br />Fuerza sin violencia.<br />Comienza tu camino en el tatami.</p>
    <a href="#clases" class="cta hero-anim">Ver Horarios</a>
  </div>
  <div class="hero-image">
    <img src="/dojo.jpeg" alt="Clase de Aikido en el dojo" />
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 1.8fr;
    min-height: 100vh;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 4rem 3rem;
    background: var(--color-dark);
    color: #fff;
  }

  .hero-anim {
    opacity: 0;
    transform: translateY(20px);
    animation: heroFadeIn 0.9s ease forwards;
  }

  .hero-anim:nth-child(1) { animation-delay: 0.2s; }
  .hero-anim:nth-child(2) { animation-delay: 0.45s; }
  .hero-anim:nth-child(3) { animation-delay: 0.7s; }
  .hero-anim:nth-child(4) { animation-delay: 0.95s; }

  @keyframes heroFadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .subtitle {
    text-transform: uppercase;
    letter-spacing: 0.35em;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 1.5rem;
  }

  h1 {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 6vw, 5.5rem);
    font-weight: 300;
    letter-spacing: 0.12em;
    line-height: 1;
    margin-bottom: 2rem;
  }

  .tagline {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 3rem;
    line-height: 2;
  }

  .cta {
    display: inline-block;
    align-self: flex-start;
    padding: 0.8rem 2.5rem;
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.85rem;
    transition: all 0.3s;
  }

  .cta:hover {
    background: #fff;
    color: var(--color-dark);
  }

  .hero-image {
    overflow: hidden;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: right;
    animation: slowZoom 20s ease forwards;
  }

  @keyframes slowZoom {
    from { transform: scale(1); }
    to { transform: scale(1.08); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-anim {
      opacity: 1;
      transform: none;
      animation: none;
    }
    .hero-image img {
      animation: none;
    }
  }

  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .hero-text {
      padding: 7rem 2rem 3rem;
      order: 1;
    }

    .hero-image {
      order: 2;
      height: 60vh;
    }
  }
</style>
