---
const schedule = [
  { day: 'Martes', time: '19:30 – 21:00', level: 'Todos los niveles', desc: 'Fundamentos, ukemi y técnicas básicas' },
  { day: 'Jueves', time: '19:30 – 21:00', level: 'Todos los niveles', desc: 'Técnica, fluidez y práctica libre' },
];
---

<section id="clases" class="classes">
  <div class="container">
    <h2 class="reveal">Clases y Horarios</h2>
    <div class="table-wrap reveal reveal-delay-1">
      <table>
        <thead>
          <tr>
            <th>Día</th>
            <th>Horario</th>
            <th>Nivel</th>
            <th>Enfoque</th>
          </tr>
        </thead>
        <tbody>
          {schedule.map((cls) => (
            <tr>
              <td>{cls.day}</td>
              <td>{cls.time}</td>
              <td>{cls.level}</td>
              <td>{cls.desc}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="note">La primera clase es gratuita. No se necesita experiencia previa para las clases de todos los niveles. Los niños deben venir acompañados de un padre o tutor en la primera clase.</p>
  </div>
</section>

<style>
  .classes {
    padding: 6rem 2rem;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  h2 {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 300;
    letter-spacing: 0.08em;
    text-align: center;
    margin-bottom: 3rem;
    color: var(--color-dark);
  }

  h2::after {
    content: '';
    display: block;
    width: 40px;
    height: 2px;
    background: var(--color-accent);
    margin: 1rem auto 0;
  }

  .table-wrap {
    overflow-x: auto;
    margin-bottom: 2rem;
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  th {
    text-align: left;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    padding: 0.75rem 1rem;
    border-bottom: 2px solid var(--color-border);
  }

  td {
    padding: 1rem;
    border-bottom: 1px solid var(--color-border);
    font-size: 0.95rem;
  }

  tr:hover {
    background: var(--color-surface);
  }

  tr {
    transition: background 0.2s, transform 0.2s;
  }

  tr:hover {
    background: var(--color-surface);
    transform: translateX(4px);
  }

  .note {
    text-align: center;
    color: var(--color-muted);
    font-size: 0.85rem;
  }
</style>
